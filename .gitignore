# Environment secrets — NEVER commit these
backend/.env
frontend/.env
frontend/.env.*

# Dependencies
node_modules/
*/node_modules/

# Build output
frontend/dist/
frontend/.vite/

# Uploaded files (user content — stored as Docker volume in prod)
backend/uploads/

# Database file fallback (local dev only)
backend/data/*.json

# Logs
*.log
npm-debug.log*

# OS / Editor
.DS_Store
.vscode/
.idea/

# ngrok artifacts
*.ngrok*
