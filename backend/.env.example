PORT=5001

# MongoDB (set automatically by docker-compose)
MONGODB_URI=mongodb://mongo:27017/biteqr

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# The Gmail address allowed to access the admin panel
ADMIN_EMAIL=your-admin@gmail.com

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Your VM's public IP or domain (no trailing slash)
FRONTEND_URL=http://YOUR_VM_IP
GOOGLE_CALLBACK_URL=http://YOUR_VM_IP/api/auth/google/callback

# Cloudinary (optional — leave blank for local disk storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
